<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/OpenSim-NGC/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <!--
      For local development, authenticate to GitHub Packages with a Personal Access Token
      that has the 'read:packages' scope.  Set the environment variable GITHUB_TOKEN, or
      populate the password below and keep it out of source control.
    -->
    <github>
      <add key="Username" value="%GITHUB_ACTOR%" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </github>
  </packageSourceCredentials>
</configuration>
